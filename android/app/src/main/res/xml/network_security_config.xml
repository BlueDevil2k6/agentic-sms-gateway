<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration.

    Trusts the self-signed CA certificate bundled at res/raw/sms_bridge_cert.pem.
    Replace that file with YOUR server's cert before building:

        # On the server, generate / locate your cert:
        sms-bridge gencert

        # Copy it into the Android project (from the machine that has the source):
        scp ubuntu@your-server:~/.sms-gateway/cert.pem \
            android/app/src/main/res/raw/sms_bridge_cert.pem

        # Rebuild and reinstall the APK.

    The file committed in the repo is a localhost placeholder — it will not
    work against a real server until you replace it with your cert.
-->
<network-security-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- System CAs (Let's Encrypt, DigiCert, etc.) -->
            <certificates src="system"/>
            <!-- Bundled self-signed CA cert — replace sms_bridge_cert.pem before building -->
            <certificates src="@raw/sms_bridge_cert"/>
        </trust-anchors>
    </base-config>

    <!-- Allow plain ws:// only for localhost / Android emulator host (dev only) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
