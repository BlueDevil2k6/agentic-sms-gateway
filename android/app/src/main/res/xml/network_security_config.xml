<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration.

    Allows user-installed CA certificates (e.g. a self-signed cert installed
    on the device via Settings → Security → Install certificate).  Android 7+
    ignores user CAs by default; this config re-enables them for this app only.

    cleartextTrafficPermitted="false" blocks plain ws:// everywhere except the
    localhost domain-config below (used for emulator / local dev).
-->
<network-security-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust normal system CAs (Let's Encrypt, DigiCert, etc.) -->
            <certificates src="system"/>
            <!-- Also trust CAs the user has manually installed on the device.
                 Install your self-signed cert via:
                   adb push cert.pem /sdcard/
                 then Settings → Security → Encryption & credentials
                      → Install a certificate → CA certificate -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <!-- Allow plain ws:// only for localhost / Android emulator host -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
