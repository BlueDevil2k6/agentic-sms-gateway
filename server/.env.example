# SMS Bridge Server — Environment Configuration
# Copy this file to .env and fill in your values

# ── Authentication ─────────────────────────────────────────────────────────────
# API key used by both the Android app and the agent framework
# Generate with: python -c "import secrets; print('sk-bridge-' + secrets.token_hex(32))"
API_KEY=sk-bridge-changeme

# ── Server Ports ───────────────────────────────────────────────────────────────
# MCP SSE server (agent-facing)
MCP_PORT=8080

# WebSocket server (Android-facing)
WS_PORT=8765

# Public WebSocket URL — embedded in the setup QR code scanned by the Android app.
# Must be the externally reachable address of this server (not localhost).
# Use wss:// for production (TLS). Use ws:// for local development only.
WS_URL=wss://your-server.com:8765

# ── FCM (Firebase Cloud Messaging) ────────────────────────────────────────────
# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts
FCM_SERVICE_ACCOUNT_PATH=/secrets/fcm-service-account.json

# ── Message Queue ──────────────────────────────────────────────────────────────
# Directory where message queue files are stored
DATA_DIR=/app/data

# Number of days before completed messages are deleted (failed messages are never auto-deleted)
MESSAGE_RETENTION_DAYS=7

# Maximum send attempts before a message is moved to failed/
MAX_SEND_ATTEMPTS=5

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
